<?xml version="1.0" encoding="utf-8"?>
<!-- RemoteViews only supports a limited set of view classes (no ConstraintLayout,
     no custom views) — plain LinearLayout/TextView is deliberate here, not an
     oversight. Three fixed rows (not a RemoteViewsService list) to keep the widget
     simple; unused rows are set to View.GONE by the provider when there are fewer
     than 3 upcoming renewals. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#06070C"
    android:padding="14dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_title"
        android:textColor="#8B8FA8"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.05" />

    <LinearLayout
        android:id="@+id/widget_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/widget_merchant_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#F1F2F7"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />
        <TextView
            android:id="@+id/widget_amount_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#F1F2F7"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/widget_merchant_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#C7C9D9"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />
        <TextView
            android:id="@+id/widget_amount_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#C7C9D9"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/widget_merchant_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#C7C9D9"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />
        <TextView
            android:id="@+id/widget_amount_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#C7C9D9"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/widget_empty"
        android:textColor="#8B8FA8"
        android:textSize="12sp"
        android:visibility="gone" />

</LinearLayout>
